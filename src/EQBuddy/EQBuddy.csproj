<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>EQBuddy</AssemblyName>
    <RootNamespace>EQBuddy</RootNamespace>
    <Version>1.8.15</Version>
    <!-- Do NOT enable InvariantGlobalization: WPF binding culture lookup
         (XmlLanguage.GetSpecificCulture) throws under it. -->
    <ApplicationIcon>Assets\EQBuddy.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\EQBuddy.Core\EQBuddy.Core.csproj" />
    <ProjectReference Include="..\EQBuddy.UI.Shared\EQBuddy.UI.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\tutorial\*.png" />
  </ItemGroup>

</Project>
